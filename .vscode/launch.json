{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug executable 'tensaku'",
            "cargo": {
                "args": [
                    "build",
                    "--bin=tensaku",
                    "--package=tensaku",
                ],
                "filter": {
                    "name": "tensaku",
                    "kind": "bin"
                }
            },
            "args": [
                "--filename",
                "/tmp/bug.png",
                "--output-filename",
                "/tmp/out.png"
            ],
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug unit tests in executable 'tensaku'",
            "cargo": {
                "args": [
                    "test",
                    "--no-run",
                    "--bin=tensaku",
                    "--package=tensaku"
                ],
                "filter": {
                    "name": "tensaku",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        }
    ]
}
